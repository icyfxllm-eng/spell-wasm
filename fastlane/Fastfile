default_platform(:ios)

# Assumes the web assets are already built and synced into the iOS project:
#   npm run build && npx cap sync ios
# (The GitHub Actions ios job / your release script does this before calling
# these lanes.)
platform :ios do
  desc "Fetch signing certs & profiles (read-only)"
  lane :certs do
    match(type: "appstore", readonly: true)
  end

  desc "Build a signed App Store IPA and upload to TestFlight"
  lane :beta do
    match(type: "appstore", readonly: is_ci)

    # match installs an "Apple Distribution" cert + this App Store profile and
    # exports its name via ENV. Force MANUAL signing so a headless/CI archive
    # never needs Xcode to interactively create a distribution profile.
    profile_name = ENV["sigh_net.spellgame.app_appstore_profile-name"]
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/App/App.xcodeproj",
      team_id: "WCH6H5NAWH",
      bundle_identifier: "net.spellgame.app",
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: ["App"]
    )

    gym(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      clean: true,
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "net.spellgame.app" => profile_name
        }
      }
    )
    pilot(
      skip_waiting_for_build_processing: true,
      changelog: "See release notes."
    )
  end

  desc "Build, upload, and submit to external TestFlight (Beta App Review)"
  lane :beta_external do
    match(type: "appstore", readonly: is_ci)
    profile_name = ENV["sigh_net.spellgame.app_appstore_profile-name"]
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/App/App.xcodeproj",
      team_id: "WCH6H5NAWH",
      bundle_identifier: "net.spellgame.app",
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: ["App"]
    )
    gym(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      clean: true,
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: { "net.spellgame.app" => profile_name }
      }
    )
    pilot(
      distribute_external: true,
      groups: ["Spell"],
      notify_external_testers: true,
      beta_app_feedback_email: "icyfxllm@gmail.com",
      beta_app_description: "Spell is a spelling game you play by ear. Tap the glowing orb to hear a word, then spell it on the on-screen keyboard and press Check. Replay or slow the word, use Definition/Sentence hints, and grow your chain. Fully playable offline after first load.",
      changelog: "Please try: tapping the orb to hear words, spelling on the on-screen keyboard, Replay/Slow, Definition/Sentence hints, head-to-head mode, and Kid Mode / Big Text in Settings.",
      beta_app_review_info: {
        contact_email: "icyfxllm@gmail.com",
        contact_first_name: "Eric",
        contact_last_name: "Hillman",
        contact_phone: "2604584592",
        demo_account_required: false,
        notes: "Native iOS spelling game, fully playable offline. No account or login required; no demo account needed. Tap the orb to hear a word, spell it on the on-screen keyboard, and press Check spelling."
      }
    )
  end

  desc "Submit the latest build to App Store review (metadata/screenshots already uploaded)"
  lane :submit_review do
    deliver(
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      build_number: "20",
      submit_for_review: true,
      run_precheck_before_submit: false,   # app has no IAP; precheck can't check IAP via API key
      automatic_release: true,
      force: true,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
        content_rights_contains_third_party_content: false
      }
    )
  end

  desc "Upload localized metadata + screenshots and submit the latest build for review"
  lane :submit_localized do
    deliver(
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      build_number: "20",
      submit_for_review: true,
      run_precheck_before_submit: false,
      automatic_release: true,
      force: true,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
        content_rights_contains_third_party_content: false
      }
    )
  end

  desc "Bump the iOS build number to the next TestFlight number"
  lane :bump do
    increment_build_number(
      xcodeproj: "ios/App/App.xcodeproj",
      build_number: latest_testflight_build_number(initial_build_number: 0) + 1
    )
  end
end
