# fastlane match stores encrypted signing certs + profiles in a SEPARATE
# PRIVATE git repo — this solves "certs on a disposable remote Mac" cleanly.
# Create an empty private repo (e.g. spell-certs) and point git_url at it.
git_url("git@github.com:icyfxllm-eng/spell-certs.git")
storage_mode("git")
type("appstore")            # `development` / `adhoc` also available
app_identifier(["net.spellgame.app"])

# Non-interactive keychain so cert import + partition-list setting don't need a GUI prompt.
keychain_name("fastlane_tmp.keychain-db")
keychain_password("fastlane_ci_temp_pw")

# First run (once, on the Mac, to create + upload the certs):
#   bundle exec fastlane match appstore
# CI / subsequent runs pull read-only (see Fastfile).
