# Copy this file to .env (never commit the real one) and fill in real values.
# docker-compose.yml's backend service reads this via env_file.

# Google Cloud Text-to-Speech API key.
# Get one at https://console.cloud.google.com/apis/credentials after
# enabling the "Cloud Text-to-Speech API" on a project with billing enabled.
GOOGLE_TTS_API_KEY=

# Optional: comma-separated extra origins allowed to call the backend
# directly (only matters if the frontend is ever hosted somewhere other
# than this same domain/reverse proxy).
ALLOWED_ORIGINS=

# Absolute path to the Cloudflare Tunnel credentials JSON created by
# `cloudflared tunnel create <name>` (see DEPLOY.md). Mounted read-only
# into the cloudflared container; routing lives in cloudflared/config.yml.
CLOUDFLARE_CREDENTIALS_FILE=

# ---------- The Climb (accounts + leaderboard) ----------
# All optional. Left blank, the leaderboard still works, but:
#   - verification/password-reset emails are only LOGGED (not delivered)
#   - signup has NO bot protection
#
# Email delivery via Resend (https://resend.com). Create an account, verify the
# sending domain `spellgame.net` (add the DNS records they give you in your
# Cloudflare DNS), then create an API key. EMAIL_FROM must be on that verified
# domain. Safe to enable on its own — no frontend change needed.
RESEND_API_KEY=
EMAIL_FROM=Spell <noreply@spellgame.net>

# Cloudflare Turnstile secret (anti-bot on signup).
# ⚠️ DO NOT SET THIS YET. The frontend signup form does not render a Turnstile
# widget, so it sends no token — a set secret makes verification fail and blocks
# EVERY signup. Enable only AFTER the widget + site key are added to the signup
# UI. Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET=

# Base URL used in verification/reset email links. Defaults to https://spellgame.net.
FRONTEND_BASE=https://spellgame.net
