# Copy this file to .env (never commit the real one) and fill in real values.
# docker-compose.yml's backend service reads this via env_file.

# Google Cloud Text-to-Speech API key.
# Get one at https://console.cloud.google.com/apis/credentials after
# enabling the "Cloud Text-to-Speech API" on a project with billing enabled.
GOOGLE_TTS_API_KEY=

# Optional: comma-separated extra origins allowed to call the backend
# directly (only matters if the frontend is ever hosted somewhere other
# than this same domain/reverse proxy).
ALLOWED_ORIGINS=

# Absolute path to the Cloudflare Tunnel credentials JSON created by
# `cloudflared tunnel create <name>` (see DEPLOY.md). Mounted read-only
# into the cloudflared container; routing lives in cloudflared/config.yml.
CLOUDFLARE_CREDENTIALS_FILE=
