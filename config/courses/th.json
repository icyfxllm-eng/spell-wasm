  "units": [
    {
      "id": "th-u1-mid",
      "title": "Mid-class consonants",
      "lessons": [
        {
          "id": "th-u1-l1",
          "title": "Mid-class consonants",
          "prerequisites": [],
          "steps": [
            {
              "type": "element",
              "element": "ก",
              "name": "ko kai",
              "cls": "mid",
              "strings": [
                "Mid-class consonant, sound k (unaspirated), as in 'sky'.",
                "Thai has 3 consonant classes - mid, high, low - that set a syllable's tone."
              ]
            },
            {
              "type": "element",
              "element": "จ",
              "name": "cho chan",
              "cls": "mid",
              "strings": [
                "Mid-class consonant, sound like 'j' but unaspirated."
              ]
            },
            {
              "type": "element",
              "element": "ด",
              "name": "do dek",
              "cls": "mid",
              "strings": [
                "Mid-class consonant, sound d."
              ]
            },
            {
              "type": "element",
              "element": "ต",
              "name": "to tao",
              "cls": "mid",
              "strings": [
                "Mid-class consonant, sound t (unaspirated), as in 'stop'."
              ]
            },
            {
              "type": "element",
              "element": "บ",
              "name": "bo baimai",
              "cls": "mid",
              "strings": [
                "Mid-class consonant, sound b."
              ]
            },
            {
              "type": "element",
              "element": "ป",
              "name": "po pla",
              "cls": "mid",
              "strings": [
                "Mid-class consonant, sound p (unaspirated), as in 'spin'."
              ]
            },
            {
              "type": "element",
              "element": "อ",
              "name": "o ang",
              "cls": "mid",
              "strings": [
                "Silent mid-class consonant; it also carries the vowel when a word starts with a vowel sound."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "th-u2-high",
      "title": "High-class consonants",
      "lessons": [
        {
          "id": "th-u2-l1",
          "title": "High-class consonants",
          "prerequisites": [
            "th-u1-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "ส",
              "name": "so sua",
              "cls": "high",
              "strings": [
                "High-class consonant, sound s.",
                "High-class letters take a rising or low tone; class plus vowel length set the tone."
              ]
            },
            {
              "type": "element",
              "element": "ห",
              "name": "ho hip",
              "cls": "high",
              "strings": [
                "High-class consonant, sound h.",
                "Written silently before some low-class letters to raise their tone (a 'leading' h)."
              ]
            },
            {
              "type": "element",
              "element": "ข",
              "name": "kho khai",
              "cls": "high",
              "strings": [
                "High-class consonant, sound k with a puff of air (aspirated)."
              ]
            },
            {
              "type": "element",
              "element": "ถ",
              "name": "tho thung",
              "cls": "high",
              "strings": [
                "High-class consonant, sound t with a puff of air (aspirated)."
              ]
            },
            {
              "type": "element",
              "element": "ผ",
              "name": "pho phung",
              "cls": "high",
              "strings": [
                "High-class consonant, sound p with a puff of air (aspirated)."
              ]
            },
            {
              "type": "element",
              "element": "ฝ",
              "name": "fo fa",
              "cls": "high",
              "strings": [
                "High-class consonant, sound f."
              ]
            },
            {
              "type": "element",
              "element": "ศ",
              "name": "so sala",
              "cls": "high",
              "strings": [
                "High-class consonant, sound s; used in some borrowed spellings."
              ]
            },
            {
              "type": "element",
              "element": "ษ",
              "name": "so rusi",
              "cls": "high",
              "strings": [
                "High-class consonant, sound s; used in some borrowed spellings."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "th-u3-low",
      "title": "Low-class consonants",
      "lessons": [
        {
          "id": "th-u3-l1",
          "title": "Low-class consonants A",
          "prerequisites": [
            "th-u2-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "ง",
              "name": "ngo ngu",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound 'ng' as in 'sing'; it can start a syllable in Thai.",
                "Low-class letters take mid or high tone; many share a sound with a high-class twin."
              ]
            },
            {
              "type": "element",
              "element": "ม",
              "name": "mo ma",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound m."
              ]
            },
            {
              "type": "element",
              "element": "น",
              "name": "no nu",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound n."
              ]
            },
            {
              "type": "element",
              "element": "ร",
              "name": "ro rua",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound r (trilled or flapped)."
              ]
            },
            {
              "type": "element",
              "element": "ว",
              "name": "wo waen",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound w; it can also form part of a vowel."
              ]
            },
            {
              "type": "element",
              "element": "ย",
              "name": "yo yak",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound y as in 'yes'."
              ]
            },
            {
              "type": "element",
              "element": "ล",
              "name": "lo ling",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound l."
              ]
            },
            {
              "type": "element",
              "element": "พ",
              "name": "pho phan",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound p with a puff of air (aspirated)."
              ]
            }
          ]
        },
        {
          "id": "th-u3-l2",
          "title": "Low-class consonants B",
          "prerequisites": [
            "th-u3-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "ท",
              "name": "tho thahan",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound t with a puff of air (aspirated)."
              ]
            },
            {
              "type": "element",
              "element": "ค",
              "name": "kho khwai",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound k with a puff of air (aspirated)."
              ]
            },
            {
              "type": "element",
              "element": "ธ",
              "name": "tho thong",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound t aspirated; used in some borrowed spellings."
              ]
            },
            {
              "type": "element",
              "element": "ฟ",
              "name": "fo fan",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound f."
              ]
            },
            {
              "type": "element",
              "element": "ภ",
              "name": "pho samphao",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound p aspirated; used in some borrowed spellings."
              ]
            },
            {
              "type": "element",
              "element": "ณ",
              "name": "no nen",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound n; used in some borrowed spellings."
              ]
            },
            {
              "type": "element",
              "element": "ช",
              "name": "cho chang",
              "cls": "low",
              "strings": [
                "Low-class consonant, sound ch (aspirated)."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "th-u4-vowels",
      "title": "Vowels",
      "lessons": [
        {
          "id": "th-u4-l1",
          "title": "Core vowels",
          "prerequisites": [
            "th-u3-l2"
          ],
          "steps": [
            {
              "type": "element",
              "element": "ะ",
              "name": "sara a",
              "strings": [
                "Short vowel 'a'. Written after the consonant.",
                "Vowels attach around a consonant - after, before, above, or below it."
              ]
            },
            {
              "type": "element",
              "element": "า",
              "name": "sara aa",
              "strings": [
                "Long vowel 'aa'. Written after the consonant."
              ]
            },
            {
              "type": "element",
              "element": "ิ",
              "name": "sara i",
              "strings": [
                "Short vowel 'i'. Written above the consonant."
              ]
            },
            {
              "type": "element",
              "element": "ี",
              "name": "sara ii",
              "strings": [
                "Long vowel 'ii'. Written above the consonant."
              ]
            },
            {
              "type": "element",
              "element": "ึ",
              "name": "sara ue",
              "strings": [
                "Short vowel 'ue' (unrounded). Written above the consonant."
              ]
            },
            {
              "type": "element",
              "element": "ื",
              "name": "sara uee",
              "strings": [
                "Long vowel 'uee' (unrounded). Written above; needs อ written after."
              ]
            },
            {
              "type": "element",
              "element": "ุ",
              "name": "sara u",
              "strings": [
                "Short vowel 'u'. Written below the consonant."
              ]
            },
            {
              "type": "element",
              "element": "ู",
              "name": "sara uu",
              "strings": [
                "Long vowel 'uu'. Written below the consonant."
              ]
            },
            {
              "type": "element",
              "element": "เ",
              "name": "sara e",
              "strings": [
                "Vowel 'e'. Written BEFORE the consonant, though sounded after it."
              ]
            },
            {
              "type": "element",
              "element": "แ",
              "name": "sara ae",
              "strings": [
                "Vowel 'ae'. Written before the consonant."
              ]
            },
            {
              "type": "element",
              "element": "โ",
              "name": "sara o",
              "strings": [
                "Vowel 'o'. Written before the consonant."
              ]
            },
            {
              "type": "element",
              "element": "ไ",
              "name": "sara ai",
              "strings": [
                "Vowel 'ai'. Written before the consonant."
              ]
            },
            {
              "type": "element",
              "element": "ใ",
              "name": "sara ai maimuan",
              "strings": [
                "Vowel 'ai', a special spelling used in about 20 set words."
              ]
            },
            {
              "type": "element",
              "element": "ำ",
              "name": "sara am",
              "strings": [
                "Vowel 'am'. Written after the consonant."
              ]
            },
            {
              "type": "element",
              "element": "ั",
              "name": "mai han-akat",
              "strings": [
                "Short 'a' used when the syllable ends in a consonant. Written above."
              ]
            },
            {
              "type": "element",
              "element": "็",
              "name": "maitaikhu",
              "strings": [
                "Shortens the vowel in a closed syllable. Written above."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "th-u5-tones",
      "title": "Tone marks and the silencer",
      "lessons": [
        {
          "id": "th-u5-l1",
          "title": "Tone marks",
          "prerequisites": [
            "th-u4-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "่",
              "name": "mai ek",
              "strings": [
                "First tone mark. The tone it makes depends on the consonant's class.",
                "A syllable's tone comes from consonant class, vowel length, and any tone mark."
              ]
            },
            {
              "type": "element",
              "element": "้",
              "name": "mai tho",
              "strings": [
                "Second tone mark. Its tone also depends on the consonant class."
              ]
            },
            {
              "type": "element",
              "element": "๊",
              "name": "mai tri",
              "strings": [
                "Third tone mark. Mostly used with mid-class consonants."
              ]
            },
            {
              "type": "element",
              "element": "๋",
              "name": "mai chattawa",
              "strings": [
                "Fourth tone mark. Mostly used with mid-class consonants."
              ]
            },
            {
              "type": "element",
              "element": "์",
              "name": "thanthakhat",
              "strings": [
                "Marks a letter as silent, common in borrowed words. Written above."
              ]
            }
          ]
        }
      ]
    },
