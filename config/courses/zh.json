    {
      "id": "zh-u3-tones",
      "title": "Tone marking",
      "lessons": [
        {
          "id": "zh-u3-l1",
          "title": "The four tones plus neutral",
          "prerequisites": [
            "zh-u2-l2"
          ],
          "steps": [
            {
              "type": "element",
              "element": "ā",
              "name": "tone 1",
              "strings": [
                "Tone 1: a high, level pitch.",
                "Tones are marked over the main vowel; there are 4 tones plus a neutral one."
              ]
            },
            {
              "type": "element",
              "element": "á",
              "name": "tone 2",
              "strings": [
                "Tone 2: a rising pitch."
              ]
            },
            {
              "type": "element",
              "element": "ǎ",
              "name": "tone 3",
              "strings": [
                "Tone 3: dips low, then rises."
              ]
            },
            {
              "type": "element",
              "element": "à",
              "name": "tone 4",
              "strings": [
                "Tone 4: a sharp falling pitch."
              ]
            },
            {
              "type": "element",
              "element": "a",
              "name": "neutral tone",
              "strings": [
                "Neutral tone: light and short, written with no mark."
              ]
            },
            {
              "type": "element",
              "element": "◌",
              "name": "tone placement",
              "strings": [
                "Put the mark on a; else o; else e. In 'iu' and 'ui' it goes on the last vowel."
              ]
            }
          ]
        }
      ]
    }
  ]
}
