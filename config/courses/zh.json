              "name": "ui",
              "strings": [
                "Final UI, spelled from u+ei."
              ]
            },
            {
              "type": "element",
              "element": "uan",
              "name": "uan",
              "strings": [
                "Final UAN."
              ]
            },
            {
              "type": "element",
              "element": "un",
              "name": "un",
              "strings": [
                "Final UN, spelled from u+en."
              ]
            },
            {
              "type": "element",
              "element": "uang",
              "name": "uang",
              "strings": [
                "Final UANG."
              ]
            },
            {
              "type": "element",
              "element": "ueng",
              "name": "ueng",
              "strings": [
                "Final UENG."
              ]
            },
            {
              "type": "element",
