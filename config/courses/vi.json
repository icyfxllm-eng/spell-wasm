{
  "schemaVersion": "0.1-draft",
  "language": "vi",
  "languageName": "Vietnamese",
  "kind": "script-path",
  "scope": "writing-system-only",
  "linear": true,
  "wordSource": "assets/words/vi (audited; referenced by text+tier, never duplicated)",
  "units": [
    {
      "id": "vi-u1-base",
      "title": "Base Latin letters",
      "lessons": [
        {
          "id": "vi-u1-l1",
          "title": "Base vowels",
          "prerequisites": [],
          "steps": [
            {
              "type": "element",
              "element": "a",
              "name": "a",
              "strings": [
                "Vowel A. Vietnamese uses the Latin alphabet, read left to right."
              ]
            },
            {
              "type": "element",
              "element": "e",
              "name": "e",
              "strings": [
                "Vowel E (open, like e in 'bet')."
              ]
            },
            {
              "type": "element",
              "element": "i",
              "name": "i",
              "strings": [
                "Vowel I ('ee')."
              ]
            },
            {
              "type": "element",
              "element": "o",
              "name": "o",
              "strings": [
                "Vowel O (open)."
              ]
            },
            {
              "type": "element",
              "element": "u",
              "name": "u",
              "strings": [
                "Vowel U ('oo')."
              ]
            },
            {
              "type": "element",
              "element": "y",
              "name": "y",
              "strings": [
                "Vowel Y; in Vietnamese Y is used as a vowel."
              ]
            }
          ]
        },
        {
          "id": "vi-u1-l2",
          "title": "Base consonants",
          "prerequisites": [
            "vi-u1-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "b",
              "name": "be",
              "strings": [
                "Consonant B."
              ]
            },
            {
              "type": "element",
              "element": "c",
              "name": "xe",
              "strings": [
                "Consonant C, sound 'k' (never soft)."
              ]
            },
            {
              "type": "element",
              "element": "d",
              "name": "de",
              "strings": [
                "Consonant D WITHOUT a stroke; sounds 'z' in the north, 'y' in the south."
              ]
            },
            {
              "type": "element",
              "element": "g",
              "name": "ge",
              "strings": [
                "Consonant G (hard g)."
              ]
            },
            {
              "type": "element",
              "element": "h",
              "name": "hat",
              "strings": [
                "Consonant H."
              ]
            },
            {
              "type": "element",
              "element": "k",
              "name": "ca",
              "strings": [
                "Consonant K, sound 'k'; used before i, e, ê."
              ]
            },
            {
              "type": "element",
              "element": "l",
              "name": "e-lo",
              "strings": [
                "Consonant L."
              ]
            },
            {
              "type": "element",
              "element": "m",
              "name": "em-mo",
              "strings": [
                "Consonant M."
              ]
            },
            {
              "type": "element",
              "element": "n",
              "name": "en-no",
              "strings": [
                "Consonant N."
              ]
            },
            {
              "type": "element",
              "element": "p",
              "name": "pe",
              "strings": [
                "Consonant P; appears mostly in the cluster 'ph' or at the end of a word."
              ]
            },
            {
              "type": "element",
              "element": "q",
              "name": "cu",
              "strings": [
                "Consonant Q; always written together with u as 'qu'."
              ]
            },
            {
              "type": "element",
              "element": "r",
              "name": "e-ro",
              "strings": [
                "Consonant R."
              ]
            },
            {
              "type": "element",
              "element": "s",
              "name": "et-si",
              "strings": [
                "Consonant S; a retroflex 'sh' in many regions."
              ]
            },
            {
              "type": "element",
              "element": "t",
              "name": "te",
              "strings": [
                "Consonant T (unaspirated)."
              ]
            },
            {
              "type": "element",
              "element": "v",
              "name": "ve",
              "strings": [
                "Consonant V."
              ]
            },
            {
              "type": "element",
              "element": "x",
              "name": "ich-xi",
              "strings": [
                "Consonant X, sound 's'."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "vi-u2-special",
      "title": "Special letters",
      "lessons": [
        {
          "id": "vi-u2-l1",
          "title": "Đ and the horned/circumflex vowels",
          "prerequisites": [
            "vi-u1-l2"
          ],
          "steps": [
            {
              "type": "element",
              "element": "đ",
              "name": "de",
              "strings": [
                "Special consonant Đ - D with a stroke, a hard 'd' as in English 'do'.",
                "These extra letters are separate letters of the alphabet, not accented versions."
              ]
            },
            {
              "type": "element",
              "element": "ă",
              "name": "a-breve",
              "strings": [
                "Special vowel Ă - a short 'a'. The breve is part of the letter, not a tone."
              ]
            },
            {
              "type": "element",
              "element": "â",
              "name": "a-circumflex",
              "strings": [
                "Special vowel Â - 'uh' (like a in 'about'). The circumflex is part of the letter."
              ]
            },
            {
              "type": "element",
              "element": "ê",
              "name": "e-circumflex",
              "strings": [
                "Special vowel Ê - a closed 'e' (like 'ay')."
              ]
            },
            {
              "type": "element",
              "element": "ô",
              "name": "o-circumflex",
              "strings": [
                "Special vowel Ô - a closed 'o' (like 'oh')."
              ]
            },
            {
              "type": "element",
              "element": "ơ",
              "name": "o-horn",
              "strings": [
                "Special vowel Ơ - 'uh'. The horn is part of the letter."
              ]
            },
            {
              "type": "element",
              "element": "ư",
              "name": "u-horn",
              "strings": [
                "Special vowel Ư - 'oo' said with unrounded lips. The horn is part of the letter."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "vi-u3-digraphs",
      "title": "Digraphs and trigraphs",
      "lessons": [
        {
          "id": "vi-u3-l1",
          "title": "Multi-letter units",
          "prerequisites": [
            "vi-u2-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "ch",
              "name": "ce-hat",
              "strings": [
                "Digraph CH, sound 'ch'.",
                "Vietnamese spells some sounds with two or three letters read as one unit."
              ]
            },
            {
              "type": "element",
              "element": "gh",
              "name": "ge-hat",
              "strings": [
                "Digraph GH, sound hard 'g'; used before i, e, ê."
              ]
            },
            {
              "type": "element",
              "element": "gi",
              "name": "ge-i",
              "strings": [
                "Digraph GI, sound 'z' (north) or 'y' (south)."
              ]
            },
            {
              "type": "element",
              "element": "kh",
              "name": "ca-hat",
              "strings": [
                "Digraph KH, a raspy 'k' sound."
              ]
            },
            {
              "type": "element",
              "element": "ng",
              "name": "en-no ge",
              "strings": [
                "Digraph NG, sound 'ng' as in 'sing'."
              ]
            },
            {
              "type": "element",
              "element": "ngh",
              "name": "en-no ge-hat",
              "strings": [
                "Trigraph NGH, sound 'ng'; used before i, e, ê."
              ]
            },
            {
              "type": "element",
              "element": "nh",
              "name": "en-no hat",
              "strings": [
                "Digraph NH, sound like 'ny'."
              ]
            },
            {
              "type": "element",
              "element": "ph",
              "name": "pe-hat",
              "strings": [
                "Digraph PH, sound 'f'."
              ]
            },
            {
              "type": "element",
              "element": "th",
              "name": "te-hat",
              "strings": [
                "Digraph TH, an aspirated 't'."
              ]
            },
            {
              "type": "element",
              "element": "tr",
              "name": "te-ro",
              "strings": [
                "Digraph TR, a 'ch'-like sound."
              ]
            },
            {
              "type": "element",
              "element": "qu",
              "name": "cu-u",
              "strings": [
                "Digraph QU, sound 'kw'."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "vi-u4-tones",
      "title": "Tone diacritics",
      "lessons": [
        {
          "id": "vi-u4-l1",
          "title": "The five tone marks",
          "prerequisites": [
            "vi-u3-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "à",
              "name": "huyen (grave)",
              "strings": [
                "Tone mark: low falling tone. Written above the main vowel.",
                "A tone mark sits on the vowel and changes only the pitch, not the letter."
              ]
            },
            {
              "type": "element",
              "element": "á",
              "name": "sac (acute)",
              "strings": [
                "Tone mark: high rising tone."
              ]
            },
            {
              "type": "element",
              "element": "ả",
              "name": "hoi (hook above)",
              "strings": [
                "Tone mark: dipping then rising tone."
              ]
            },
            {
              "type": "element",
              "element": "ã",
              "name": "nga (tilde)",
              "strings": [
                "Tone mark: broken, creaky rising tone."
              ]
            },
            {
              "type": "element",
              "element": "ạ",
              "name": "nang (dot below)",
              "strings": [
                "Tone mark: heavy low tone. Written BELOW the vowel."
              ]
            }
          ]
        }
      ]
    },
