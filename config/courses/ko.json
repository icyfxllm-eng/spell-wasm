  "units": [
    {
      "id": "ko-u1-cons",
      "title": "Basic consonants (jamo)",
      "lessons": [
        {
          "id": "ko-u1-l1",
          "title": "Basic consonants",
          "prerequisites": [],
          "steps": [
            {
              "type": "element",
              "element": "ㄱ",
              "name": "giyeok",
              "strings": [
                "Basic consonant, sound g/k. Hangul letters stack into square syllable blocks."
              ]
            },
            {
              "type": "element",
              "element": "ㄴ",
              "name": "nieun",
              "strings": [
                "Basic consonant, sound n."
              ]
            },
            {
              "type": "element",
              "element": "ㄷ",
              "name": "digeut",
              "strings": [
                "Basic consonant, sound d/t."
              ]
            },
            {
              "type": "element",
              "element": "ㄹ",
              "name": "rieul",
              "strings": [
                "Basic consonant, a sound between r and l."
              ]
            },
            {
              "type": "element",
              "element": "ㅁ",
              "name": "mieum",
              "strings": [
                "Basic consonant, sound m."
              ]
            },
            {
              "type": "element",
              "element": "ㅂ",
              "name": "bieup",
              "strings": [
                "Basic consonant, sound b/p."
              ]
            },
            {
              "type": "element",
              "element": "ㅅ",
              "name": "siot",
              "strings": [
                "Basic consonant, sound s."
              ]
            },
            {
              "type": "element",
              "element": "ㅇ",
              "name": "ieung",
              "strings": [
                "Silent at the start of a block (a placeholder); sounds 'ng' at the end of a block."
              ]
            },
            {
              "type": "element",
              "element": "ㅈ",
              "name": "jieut",
              "strings": [
                "Basic consonant, sound j."
              ]
            },
            {
              "type": "element",
              "element": "ㅎ",
              "name": "hieut",
              "strings": [
                "Basic consonant, sound h."
              ]
            },
            {
              "type": "element",
              "element": "ㅋ",
              "name": "kieuk",
              "strings": [
                "Aspirated consonant, sound k with a puff of air."
              ]
            },
            {
              "type": "element",
              "element": "ㅌ",
              "name": "tieut",
              "strings": [
                "Aspirated consonant, sound t with a puff of air."
              ]
            },
            {
              "type": "element",
              "element": "ㅍ",
              "name": "pieup",
              "strings": [
                "Aspirated consonant, sound p with a puff of air."
              ]
            },
            {
              "type": "element",
              "element": "ㅊ",
              "name": "chieut",
              "strings": [
                "Aspirated consonant, sound ch with a puff of air."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "ko-u2-vowels",
      "title": "Basic vowels (jamo)",
      "lessons": [
        {
          "id": "ko-u2-l1",
          "title": "Basic vowels",
          "prerequisites": [
            "ko-u1-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "ㅏ",
              "name": "a",
              "strings": [
                "Vowel 'a'. Vertical vowels are written to the RIGHT of the first consonant."
              ]
            },
            {
              "type": "element",
              "element": "ㅓ",
              "name": "eo",
              "strings": [
                "Vowel 'eo' (like u in 'up'). Written to the right."
              ]
            },
            {
              "type": "element",
              "element": "ㅗ",
              "name": "o",
              "strings": [
                "Vowel 'o'. Horizontal vowels are written BELOW the first consonant."
              ]
            },
            {
              "type": "element",
              "element": "ㅜ",
              "name": "u",
              "strings": [
                "Vowel 'u'. Written below."
              ]
            },
            {
              "type": "element",
              "element": "ㅡ",
              "name": "eu",
              "strings": [
                "Vowel 'eu' (unrounded). Written below."
              ]
            },
            {
              "type": "element",
              "element": "ㅣ",
              "name": "i",
              "strings": [
                "Vowel 'i'. Written to the right."
              ]
            },
            {
              "type": "element",
              "element": "ㅑ",
              "name": "ya",
              "strings": [
                "Vowel 'ya'. Written to the right."
              ]
            },
            {
              "type": "element",
              "element": "ㅕ",
              "name": "yeo",
              "strings": [
                "Vowel 'yeo'. Written to the right."
              ]
            },
            {
              "type": "element",
              "element": "ㅛ",
              "name": "yo",
              "strings": [
                "Vowel 'yo'. Written below."
              ]
            },
            {
              "type": "element",
              "element": "ㅠ",
              "name": "yu",
              "strings": [
                "Vowel 'yu'. Written below."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "ko-u3-blocks",
      "title": "Syllable-block composition",
      "lessons": [
        {
          "id": "ko-u3-l1",
          "title": "Building blocks and the batchim",
          "prerequisites": [
            "ko-u2-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "받침",
              "name": "batchim (final slot)",
              "strings": [
                "A consonant written at the BOTTOM of a block is a 'batchim' - the final sound.",
                "Read a block top-to-bottom, left-to-right: first consonant, vowel, then batchim."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "ko-u4-tense",
      "title": "Tense and complex jamo",
      "lessons": [
        {
          "id": "ko-u4-l1",
          "title": "Tense consonants",
          "prerequisites": [
            "ko-u3-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "ㄲ",
              "name": "ssang-giyeok",
              "strings": [
                "Tense consonant: a tighter, harder ㄱ. Written as two ㄱ side by side."
              ]
            },
            {
              "type": "element",
              "element": "ㄸ",
              "name": "ssang-digeut",
              "strings": [
                "Tense consonant: a tighter ㄷ."
              ]
            },
            {
              "type": "element",
              "element": "ㅃ",
              "name": "ssang-bieup",
              "strings": [
                "Tense consonant: a tighter ㅂ."
              ]
            },
            {
              "type": "element",
              "element": "ㅆ",
              "name": "ssang-siot",
              "strings": [
                "Tense consonant: a tighter ㅅ."
              ]
            },
            {
              "type": "element",
              "element": "ㅉ",
              "name": "ssang-jieut",
              "strings": [
                "Tense consonant: a tighter ㅈ."
              ]
            }
          ]
        },
        {
          "id": "ko-u4-l2",
          "title": "Complex vowels",
          "prerequisites": [
            "ko-u4-l1"
          ],
          "steps": [
            {
              "type": "element",
              "element": "ㅐ",
              "name": "ae",
              "strings": [
                "Vowel 'ae' (like e in 'bed'). A combination vowel."
              ]
            },
            {
              "type": "element",
              "element": "ㅔ",
              "name": "e",
              "strings": [
                "Vowel 'e'. Very close to ㅐ for most speakers."
              ]
            },
            {
              "type": "element",
              "element": "ㅚ",
              "name": "oe",
              "strings": [
                "Vowel 'oe' / 'we'. A combination vowel."
              ]
            },
            {
              "type": "element",
              "element": "ㅟ",
              "name": "wi",
              "strings": [
                "Vowel 'wi'. A combination vowel."
              ]
            },
            {
              "type": "element",
              "element": "ㅘ",
              "name": "wa",
              "strings": [
                "Vowel 'wa'. ㅗ plus ㅏ combined."
              ]
            },
            {
              "type": "element",
              "element": "ㅝ",
              "name": "wo",
              "strings": [
                "Vowel 'wo'. ㅜ plus ㅓ combined."
              ]
            },
            {
              "type": "element",
              "element": "ㅢ",
              "name": "ui",
              "strings": [
                "Vowel 'ui'. ㅡ plus ㅣ combined."
              ]
            },
            {
              "type": "element",
              "element": "ㅒ",
              "name": "yae",
              "strings": [
                "Vowel 'yae'. A combination vowel."
              ]
            },
            {
              "type": "element",
              "element": "ㅖ",
              "name": "ye",
              "strings": [
                "Vowel 'ye'. A combination vowel."
              ]
            }
          ]
        }
      ]
    },
