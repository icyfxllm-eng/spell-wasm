<?xml version="1.0" encoding="UTF-8"?>
<!-- Mac App Store entitlements (§3.4). Sandbox ON; the only capability needed
     is outbound network client for The Climb (leaderboard/auth). Referenced
     from a MAS build via bundle.macOS.entitlements in a MAS config overlay. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>com.apple.security.app-sandbox</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
</dict>
</plist>
