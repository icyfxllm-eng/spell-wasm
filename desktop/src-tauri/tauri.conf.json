{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpellGame",
  "version": "1.1.0",
  "identifier": "net.spellgame.desktop",
  "build": {
    "frontendDist": "../../dist",
    "beforeBuildCommand": "npm --prefix ../.. run build",
    "beforeDevCommand": "npm --prefix ../.. run build",
    "devUrl": null
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SpellGame",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Hear it, spell it — keep the chain.",
    "longDescription": "A spelling game you play with your ears — hear a word, then type, speak, or draw its spelling. Eleven languages with native keyboards, adaptive practice, and a global leaderboard.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
