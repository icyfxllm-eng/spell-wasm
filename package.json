{
  "name": "spell",
  "version": "1.0.0",
  "private": true,
  "description": "Spell — hear it, spell it. Capacitor native wrapper around the Rust/WASM PWA.",
  "scripts": {
    "i18n:check": "node scripts/i18n-check.mjs",
    "viewport:check": "node scripts/viewport-check.mjs",
    "seam:check": "node scripts/seam-absence-check.mjs dist",
    "build:test": "bash scripts/build-web-test.sh",
    "e2e": "bash scripts/build-web-test.sh && node tests/e2e/run.mjs",
    "words:build": "python3 scripts/build-wordlists.py",
    "words:check": "python3 scripts/build-wordlists.py --check",
    "kb:check": "node scripts/kb-layout-check.mjs",
    "build": "node scripts/i18n-check.mjs && node scripts/viewport-check.mjs && python3 scripts/build-wordlists.py --check && bash scripts/build-web.sh && node scripts/seam-absence-check.mjs dist",
    "sync": "npm run build && cap sync",
    "android": "npm run sync && cap run android",
    "release:android": "npm run sync && cd android && ./gradlew :app:bundleRelease",
    "sync:ios": "npm run build && cap sync ios",
    "version:set": "node scripts/bump-version.mjs",
    "check:contrast": "node scripts/check-contrast.mjs"
  },
  "dependencies": {
    "@capacitor-community/native-audio": "^8.0.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/share": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "playwright": "^1.61.1"
  }
}
